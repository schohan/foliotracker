# Google AI / Gemini (required for ADK agents)
GOOGLE_API_KEY=

# Optional: override default model
FOLIOTRACKER_MODEL=gemini-2.0-flash

# Optional: persistence
MONGO_URI=

# Phase 0 local result cache
PHASE0_CACHE_TTL_SECONDS=3600
PHASE0_CACHE_DIR=.cache/foliotracker/phase0

# Yahoo Finance HTTP timeout (seconds)
YAHOO_TIMEOUT_SECONDS=15
